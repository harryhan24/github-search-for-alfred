q="${q#"${q%%[![:space:]]*}"}"
q="${q%"${q##*[![:space:]]}"}"
ql=$(printf '%s' "$q" | tr '[:upper:]' '[:lower:]')
items=""
while IFS='|' read -r title arg subtitle match; do
  hit=0
  case " $match " in
    *" $ql"*) hit=1 ;;
  esac
  if [ -z "$ql" ] || [ "$hit" = 1 ]; then
    items="${items:+$items,}{\"title\":\"$title\",\"subtitle\":\"$subtitle\",\"arg\":\"$arg\"}"
  fi
done &lt;&lt;'DATA'
