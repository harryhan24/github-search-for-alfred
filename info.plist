raw=""
if [ -n "$q" ]; then
  esc=$(printf '%s' "$q" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')
  enc=$(printf '%s' "$q" | sed -e 's/%/%25/g' -e 's/+/%2B/g' -e 's/#/%23/g' -e 's/&amp;/%26/g' -e 's/?/%3F/g' -e 's/"/%22/g' -e 's/ /%20/g')
  raw="{\"title\":\"$esc\",\"subtitle\":\"language:$esc — use as typed\",\"arg\":\"$enc\"}"
fi
all="$raw"
if [ -n "$items" ]; then
  all="${all:+$all,}$items"
fi
printf '{"items":[%s]}' "$all"
